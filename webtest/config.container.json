{
  "interactiveLogin": false,
  "rotateRefreshToken": false,
  "staticAssetsPath": "/webtest",
  "loginTemplates": [
    {
      "name": "admin-alice",
      "subject": "template-alice",
      "claims": {
        "email": "template-alice@example.com",
        "template_marker": "from-template"
      }
    },
    {
      "name": "basic-bob",
      "subject": "template-bob"
    }
  ],
  "tokenProvider": {
    "keyProvider": {
      "algorithm": "RS256"
    }
  },
  "tokenCallbacks": [
    {
      "issuer": "configured",
      "subject": "config-seeded-subject",
      "audience": ["config-audience"],
      "typ": "at+jwt",
      "expirySeconds": 3600,
      "claims": {
        "config_marker": "from-config"
      }
    }
  ]
}
